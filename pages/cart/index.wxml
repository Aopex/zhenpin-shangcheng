<view class="page">
  <view class="section-title">购物车</view>

  <view class="cart-list">
    <view class="cart-card" wx:for="{{cartList}}" wx:key="id">
      <view>
        <text class="item-name">{{item.name}}</text>
        <text class="item-count">数量 x{{item.count}}</text>
      </view>
      <text class="item-price">¥{{item.price}}</text>
    </view>
  </view>

  <view class="summary-card">
    <text class="summary-text">共 {{totalCount}} 件商品</text>
    <text class="summary-price">合计 ¥{{totalPrice}}</text>
    <button class="submit-btn" bindtap="goToOrder">去结算</button>
  </view>
</view>