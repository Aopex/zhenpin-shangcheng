<view class="page">
  <view class="header-card">
    <text class="header-title">我的订单</text>
    <text class="header-desc">这里展示当前订单和历史订单的示例数据。</text>
  </view>

  <view class="order-list">
    <view class="order-card" wx:for="{{orderList}}" wx:key="id">
      <view class="order-row">
        <text class="order-id">{{item.id}}</text>
        <text class="order-status">{{item.status}}</text>
      </view>
      <view class="order-row secondary-row">
        <text class="order-date">下单时间 {{item.date}}</text>
        <text class="order-amount">¥{{item.amount}}</text>
      </view>
    </view>
  </view>

  <button class="back-btn" bindtap="goToShop">继续购物</button>
</view>