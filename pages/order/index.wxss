page {
  min-height: 100%;
  background: #f5f7fb;
}

.page {
  padding: 28rpx 24rpx 40rpx;
}

.header-card,
.order-card {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.header-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.order-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.secondary-row {
  margin-top: 18rpx;
}

.order-id {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.order-status {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  font-size: 22rpx;
  color: #1f6feb;
}

.order-date {
  font-size: 24rpx;
  color: #6b7280;
}

.order-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #f04438;
}

.back-btn {
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
}