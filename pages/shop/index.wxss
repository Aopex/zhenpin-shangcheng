page {
	min-height: 100%;
	background: #f5f7fb;
}

.page {
	padding: 28rpx 24rpx 40rpx;
}

.topbar {
	display: flex;
	justify-content: space-between;
	align-items: center;
}

.title {
	font-size: 40rpx;
	font-weight: 700;
	color: #111827;
}

.top-actions {
	display: flex;
	gap: 20rpx;
}

.action-link {
	font-size: 24rpx;
	color: #1f6feb;
}

.category-scroll {
	margin-top: 24rpx;
	white-space: nowrap;
}

.category-list {
	display: inline-flex;
	gap: 16rpx;
}

.category-item {
	padding: 14rpx 24rpx;
	border-radius: 999rpx;
	background: #ffffff;
	color: #4b5563;
	font-size: 24rpx;
}

.category-item-active {
	background: #1f6feb;
	color: #ffffff;
}

.goods-list {
	display: flex;
	flex-direction: column;
	gap: 18rpx;
	margin-top: 24rpx;
}

.goods-card {
	padding: 28rpx 24rpx;
	border-radius: 24rpx;
	background: #ffffff;
	box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.goods-main {
	display: flex;
	justify-content: space-between;
	gap: 20rpx;
}

.goods-name {
	display: block;
	font-size: 30rpx;
	font-weight: 600;
	color: #111827;
}

.goods-desc {
	display: block;
	margin-top: 10rpx;
	font-size: 24rpx;
	color: #6b7280;
}

.goods-category {
	height: fit-content;
	padding: 8rpx 16rpx;
	border-radius: 999rpx;
	background: #eef4ff;
	font-size: 22rpx;
	color: #1f6feb;
}

.goods-footer {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-top: 24rpx;
}

.goods-price {
	font-size: 32rpx;
	font-weight: 700;
	color: #f04438;
}

.add-btn {
	margin: 0;
	padding: 0 22rpx;
	border-radius: 999rpx;
	background: #111827;
	color: #ffffff;
}