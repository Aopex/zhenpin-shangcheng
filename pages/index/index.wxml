<scroll-view class="page" scroll-y="true">
  <view class="hero">
    <text class="hero-title">{{bannerTitle}}</text>
    <text class="hero-desc">{{bannerDesc}}</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">快捷入口</text>
      <text class="section-subtitle">点击进入对应页面</text>
    </view>
    <view class="action-grid">
      <view class="action-card" wx:for="{{quickActions}}" wx:key="path" data-path="{{item.path}}" bindtap="goToPage">
        <text class="action-name">{{item.name}}</text>
        <text class="action-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">首页推荐</text>
      <text class="section-subtitle">示例商品数据</text>
    </view>
    <view class="goods-list">
      <view class="goods-card" wx:for="{{featuredGoods}}" wx:key="id">
        <view>
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-tag">{{item.tag}}</text>
        </view>
        <text class="goods-price">¥{{item.price}}</text>
      </view>
    </view>
  </view>
</scroll-view>
