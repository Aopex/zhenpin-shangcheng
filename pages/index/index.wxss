page {
  height: 100%;
  background: #f5f7fb;
}

.page {
  height: 100%;
  box-sizing: border-box;
  padding: 32rpx 24rpx 40rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #1f6feb, #57a6ff);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(31, 111, 235, 0.18);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.92;
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.section-subtitle {
  font-size: 22rpx;
  color: #667085;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.action-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.action-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.goods-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.goods-tag {
  display: inline-block;
  margin-top: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1f6feb;
  font-size: 20rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #f04438;
}
