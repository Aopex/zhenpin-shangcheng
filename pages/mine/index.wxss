page {
	min-height: 100%;
	background: #f5f7fb;
}

.page {
	padding: 28rpx 24rpx 40rpx;
}

.profile-card {
	display: flex;
	gap: 24rpx;
	align-items: center;
	padding: 32rpx 28rpx;
	border-radius: 28rpx;
	background: linear-gradient(135deg, #111827, #374151);
	color: #ffffff;
}

.avatar {
	display: flex;
	justify-content: center;
	align-items: center;
	width: 110rpx;
	height: 110rpx;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.18);
	font-size: 36rpx;
	font-weight: 700;
}

.profile-content {
	display: flex;
	flex-direction: column;
	gap: 10rpx;
}

.profile-name {
	font-size: 34rpx;
	font-weight: 700;
}

.profile-level {
	font-size: 24rpx;
	color: #d1d5db;
}

.profile-desc {
	font-size: 24rpx;
	line-height: 1.6;
	color: #e5e7eb;
}

.service-panel {
	margin-top: 28rpx;
	padding: 28rpx 24rpx;
	border-radius: 24rpx;
	background: #ffffff;
	box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.panel-title {
	display: block;
	margin-bottom: 20rpx;
	font-size: 30rpx;
	font-weight: 700;
	color: #111827;
}

.service-list {
	display: flex;
	flex-direction: column;
}

.service-item {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 22rpx 0;
	border-bottom: 1rpx solid #eef2f6;
}

.service-item:last-child {
	border-bottom: 0;
}

.service-name {
	font-size: 28rpx;
	color: #1f2937;
}

.service-arrow {
	font-size: 28rpx;
	color: #9ca3af;
}