<view class="page">
	<view class="profile-card">
		<view class="avatar">我</view>
		<view class="profile-content">
			<text class="profile-name">{{profile.name}}</text>
			<text class="profile-level">{{profile.level}}</text>
			<text class="profile-desc">{{profile.desc}}</text>
		</view>
	</view>

	<view class="service-panel">
		<text class="panel-title">常用服务</text>
		<view class="service-list">
			<view class="service-item" wx:for="{{serviceList}}" wx:key="name" data-path="{{item.path}}" data-name="{{item.name}}" bindtap="goToPage">
				<text class="service-name">{{item.name}}</text>
				<text class="service-arrow">></text>
			</view>
		</view>
	</view>
</view>