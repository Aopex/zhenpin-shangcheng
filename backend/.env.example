# Docker Compose 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ==================== 数据库配置 ====================
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=123456

# ==================== Redis 配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
# 【重要】生产环境必须使用强密钥（至少32字符）
# 生成强密钥命令: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG
JWT_EXPIRATION=86400000

# ==================== 微信配置 ====================
# 从微信公众平台获取（https://mp.weixin.qq.com/）
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# ==================== 应用配置 ====================
SPRING_PROFILES_ACTIVE=prod
