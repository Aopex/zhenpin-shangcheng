.search-page {
  min-height: 100vh;
  background: var(--bg-page);
}

.search-top {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: rgba(249, 247, 243, 0.88);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.7);
}

.search-box {
  flex: 1;
  height: 76rpx;
  border-radius: 38rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid rgba(235, 229, 223, 0.8);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.6);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  color: var(--text-main);
  font-size: 28rpx;
}

.search-placeholder,
.filter-placeholder {
  color: #B9AFAB;
}

.clear-btn {
  width: 42rpx;
  height: 42rpx;
  border-radius: 21rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  background: var(--bg-input);
  font-size: 34rpx;
  line-height: 1;
}

.search-submit {
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: var(--text-main);
  font-size: 26rpx;
  font-weight: 600;
}

.sort-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 24rpx 12rpx;
  background: var(--bg-page);
}

.sort-item,
.filter-entry {
  height: 60rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  background: rgba(255,255,255,0.72);
  border: 1rpx solid transparent;
  font-size: 24rpx;
  font-weight: 600;
  transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1), color 0.22s ease, background 0.22s ease;
}

.sort-item.active,
.filter-entry.active {
  color: var(--text-main);
  background: #fff;
  border-color: var(--border-light);
  box-shadow: 0 12rpx 28rpx -22rpx rgba(54,46,45,0.22);
}

.price-arrow {
  margin-left: 6rpx;
  font-size: 22rpx;
  font-family: 'Bahnschrift', monospace;
}

.filter-entry {
  margin-left: auto;
  position: relative;
}

.filter-dot {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: #fff;
  font-size: 18rpx;
  font-family: 'Bahnschrift', monospace;
}

.chips-row {
  padding: 0 0 8rpx;
}

.chips-scroll {
  white-space: nowrap;
}

.chips-inner {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 24rpx 8rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #fff;
  color: var(--text-main);
  border: 1rpx solid var(--border-light);
  font-size: 23rpx;
}

.chip-close {
  color: var(--text-muted);
  font-size: 28rpx;
  line-height: 1;
}

.clear-all {
  color: var(--primary);
}

.result-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 18rpx 28rpx 20rpx;
}

.result-title {
  color: var(--text-main);
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.result-keyword {
  margin-left: 10rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.result-count {
  color: var(--text-muted);
  font-size: 24rpx;
  font-family: 'Bahnschrift', monospace;
}

.product-grid,
.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  padding: 0 24rpx 32rpx;
}

.product-card {
  overflow: hidden;
  border-radius: 26rpx;
  background: #fff;
  border: 1rpx solid rgba(235, 229, 223, 0.75);
  box-shadow: 0 18rpx 40rpx -30rpx rgba(54, 46, 45, 0.24);
  transition: transform 0.22s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.22s ease;
}

.active-feedback {
  opacity: 0.8;
  transform: scale(0.98);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.product-img {
  width: 100%;
  height: 330rpx;
  background: var(--bg-input);
}

.product-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.category-name {
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 600;
}

.product-title {
  min-height: 76rpx;
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 600;
  line-height: 38rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.meta-row {
  display: flex;
  gap: 14rpx;
  color: var(--text-muted);
  font-size: 21rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-top: 2rpx;
}

.price-symbol {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
}

.price-num {
  color: var(--primary);
  font-size: 36rpx;
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
}

.skeleton-card {
  border-radius: 26rpx;
  padding-bottom: 22rpx;
  background: #fff;
  overflow: hidden;
  border: 1rpx solid rgba(235, 229, 223, 0.6);
}

.skeleton-img,
.skeleton-line {
  background: linear-gradient(90deg, #F1EDE8 0%, #F8F5F1 48%, #F1EDE8 100%);
  background-size: 240% 100%;
  animation: shimmer 1.3s ease-in-out infinite;
}

.skeleton-img {
  height: 330rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
  margin: 22rpx 20rpx 0;
}

.skeleton-line.wide {
  width: 76%;
}

.skeleton-line.short {
  width: 44%;
}

@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.empty-state {
  min-height: 620rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 56rpx;
  text-align: center;
}

.empty-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: #fff;
  border: 1rpx solid var(--border-light);
  position: relative;
}

.empty-mark::after {
  content: '';
  position: absolute;
  left: 32rpx;
  top: 52rpx;
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--border-light);
}

.empty-title {
  margin-top: 28rpx;
  color: var(--text-main);
  font-size: 32rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 38rpx;
}

.empty-btn {
  margin-top: 30rpx;
  height: 70rpx;
  padding: 0 34rpx;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: var(--text-main);
  font-size: 26rpx;
  font-weight: 600;
}

.bottom-spacer {
  height: env(safe-area-inset-bottom);
}

.filter-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background-color: rgba(0,0,0,0);
  backdrop-filter: blur(0);
  -webkit-backdrop-filter: blur(0);
  visibility: hidden;
  transition: background-color 0.3s ease, backdrop-filter 0.3s ease, visibility 0.3s ease;
}

.filter-mask.show {
  background-color: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  visibility: visible;
}

.filter-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 78vh;
  overflow: hidden;
  background: var(--bg-card);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  z-index: 1000;
  transform: translateY(calc(100% + env(safe-area-inset-bottom)));
  visibility: hidden;
  pointer-events: none;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.filter-panel.show {
  transform: translateY(0);
  visibility: visible;
  pointer-events: auto;
}

.filter-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 40rpx 32rpx;
  position: relative;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}

.filter-title {
  display: block;
  color: var(--text-main);
  font-size: 34rpx;
  font-weight: 700;
}

.filter-sub {
  display: block;
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.filter-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-input);
  color: var(--text-muted);
  font-size: 40rpx;
  line-height: 1;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.filter-section {
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}

.filter-label {
  display: block;
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.category-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tag {
  height: 58rpx;
  padding: 0 24rpx;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-muted);
  background: var(--bg-page);
  border: 1rpx solid transparent;
  font-size: 24rpx;
}

.category-tag.active {
  color: #fff;
  background: var(--text-main);
}

.price-filter-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.price-input {
  flex: 1;
  height: 74rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: var(--bg-page);
  color: var(--text-main);
  font-size: 26rpx;
}

.price-divider {
  width: 28rpx;
  height: 2rpx;
  background: var(--border-light);
}

.stock-row {
  margin: 0;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}

.stock-title,
.stock-desc {
  display: block;
}

.stock-title {
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 700;
}

.stock-desc {
  margin-top: 8rpx;
  color: var(--text-muted);
  font-size: 23rpx;
}

.switch-shell {
  width: 92rpx;
  height: 52rpx;
  padding: 5rpx;
  border-radius: 26rpx;
  background: var(--bg-input);
  transition: background 0.22s ease;
}

.switch-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 21rpx;
  background: #fff;
  box-shadow: 0 6rpx 14rpx -8rpx rgba(54,46,45,0.5);
  transition: transform 0.24s cubic-bezier(0.16, 1, 0.3, 1);
}

.switch-shell.active {
  background: var(--text-main);
}

.switch-shell.active .switch-dot {
  transform: translateX(40rpx);
}

.filter-actions {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 18rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(235, 229, 223, 0.4);
}

.reset-btn,
.confirm-btn {
  height: 82rpx;
  border-radius: 41rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.reset-btn {
  color: var(--text-main);
  background: var(--bg-page);
}

.confirm-btn {
  color: #fff;
  background: var(--text-main);
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.2);
}
