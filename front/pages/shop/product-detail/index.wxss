/* pages/shop/product-detail/index.wxss */
.detail-container {
  background-color: var(--bg-page);
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.scroll-content {
  height: 100vh;
  padding-bottom: calc(108rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 轮播图区域 */
.banner-box {
  width: 100%;
  height: 750rpx;
  position: relative;
}
.banner-swiper {
  width: 100%;
  height: 100%;
}
.banner-img {
  width: 100%;
  height: 100%;
  background-color: var(--bg-input);
}
.banner-indicator {
  position: absolute;
  right: 32rpx;
  bottom: 32rpx;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #FFF;
  font-size: 24rpx;
  font-family: 'Bahnschrift', monospace; /* Sleek mono font for numbers */
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2); /* Liquid Glass inner edge */
}

/* 基本信息区 */
.info-card {
  margin: 32rpx;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  background: var(--bg-card);
  box-shadow: 0 10rpx 40rpx -15rpx rgba(0,0,0,0.04);
}
.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}
.price-main {
  color: var(--primary); /* Theme red accent */
  font-weight: 700;
  letter-spacing: -1rpx;
  font-family: 'Bahnschrift', monospace;
}
.price-symbol {
  font-size: 32rpx;
  margin-right: 4rpx;
}
.price-num {
  font-size: 64rpx; /* Bigger pricing for layout typography contrast */
}
.price-original {
  font-size: 28rpx;
  color: var(--text-muted);
  text-decoration: line-through;
  margin-left: 24rpx;
  font-family: 'Bahnschrift', monospace;
}
.title-row {
  margin-bottom: 24rpx;
}
.product-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 52rpx;
  letter-spacing: -0.5rpx;
}
.sales-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* SKU 面板呼出区 */
.sku-card {
  margin: 0 32rpx 32rpx;
  border-radius: 32rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx;
  box-shadow: 0 10rpx 40rpx -15rpx rgba(0,0,0,0.04);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.sku-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}
.sku-label {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-right: 32rpx;
  font-weight: 500;
}
.sku-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
}
.arrow-icon {
  font-size: 32rpx;
  color: var(--text-muted);
  font-family: 'Bahnschrift', monospace;
}

/* 详情介绍区 */
.detail-doc {
  margin: 32rpx;
  border-radius: 32rpx;
  background: var(--bg-card);
  padding: 0;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx -15rpx rgba(0,0,0,0.04);
}
.detail-title {
  font-size: 30rpx;
  color: var(--text-main);
  font-weight: 600;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
  letter-spacing: -0.5rpx;
}
.detail-images {
  display: flex;
  flex-direction: column;
}
.detail-img {
  width: 100%;
  display: block;
  background-color: var(--bg-input);
  margin-top: -1rpx;
}

/* 底部操作栏 - Glass & Floating style */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 100;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}
.bottom-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.bar-left {
  display: flex;
  width: 280rpx;
}
.icon-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  position: relative;
  transition: all 0.2s ease;
}
.icon-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}
.icon-img {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}
.icon-text {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-main);
}
.badge {
  position: absolute;
  top: -4rpx;
  right: 8rpx;
  background-color: var(--text-main);
  color: #FFF;
  font-size: 20rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  line-height: 28rpx;
  font-family: 'Bahnschrift', monospace;
  border: 2rpx solid #FFF;
}

/* button 客服 去样式 */
.plain-btn {
  background-color: transparent;
  line-height: normal;
  border-radius: 0;
  padding: 0;
  margin: 0;
}
.plain-btn::after {
  display: none;
}

.bar-right {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}
.btn-action {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 42rpx;
  flex: 1;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.btn-action:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.btn-add-cart {
  background-color: var(--bg-input);
  color: var(--text-main);
}
.btn-buy-now {
  background-color: var(--text-main);
  color: #FFF;
  box-shadow: 0 8rpx 16rpx -6rpx rgba(0,0,0,0.15);
}

/* SKU Mask & Popup styling updates */
.sku-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 999;
  animation: fadeIn 0.3s ease forwards;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.sku-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background-color: var(--bg-card);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  z-index: 1000;
  transform: translateY(110%);
  visibility: hidden;
  pointer-events: none;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
  padding-bottom: env(safe-area-inset-bottom);
}
.sku-popup.show {
  transform: translateY(0);
  visibility: visible;
  pointer-events: auto;
}

.sku-header {
  display: flex;
  padding: 40rpx 32rpx;
  position: relative;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}
.sku-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background-color: var(--bg-input);
  margin-top: -60rpx;
  border: 4rpx solid var(--bg-card);
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.1);
}
.sku-header-info {
  margin-left: 32rpx;
  flex: 1;
}
.sku-price {
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
}
.sku-stock, .sku-selected {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}
.sku-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 48rpx;
  color: var(--text-muted);
  line-height: 1;
  padding: 10rpx;
  transition: transform 0.2s ease;
}
.sku-close:active {
  transform: scale(0.8) rotate(90deg);
}

.sku-body {
  max-height: 50vh;
  padding: 0;
}
.sku-group {
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}
.sku-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
}
.sku-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.sku-tag {
  padding: 12rpx 32rpx;
  background-color: var(--bg-page);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-main);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}
.sku-tag:active {
  transform: scale(0.95);
}
.sku-tag.active {
  background-color: var(--text-main);
  color: #FFF;
  border-color: var(--text-main);
}
.sku-tag.disabled {
  color: var(--border-light);
  background-color: var(--bg-page);
  opacity: 0.5;
  pointer-events: none;
}

.sku-count-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stepper {
  display: flex;
  align-items: center;
  background-color: var(--bg-page);
  border-radius: 32rpx;
  padding: 4rpx;
}
.stepper-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-main);
  transition: all 0.2s;
}
.stepper-btn:active {
  background-color: rgba(0,0,0,0.05);
  border-radius: 28rpx;
}
.stepper-num {
  width: 70rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Bahnschrift', monospace;
}

.sku-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid rgba(235, 229, 223, 0.4);
}
.btn-sku-confirm {
  background-color: var(--text-main);
  color: #FFF;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.2);
  transition: all 0.2s;
}
.btn-sku-confirm:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 抛物线飞入购物车 */
.fly-img {
  position: fixed;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  z-index: 9999;
  pointer-events: none;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0,0,0,0.2);
}
.fly-img.fly-parabola {
  animation: fly-parabola 0.45s ease-in forwards;
}
@keyframes fly-parabola {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(var(--dx), var(--dy)) scale(0.3); opacity: 0.4; }
}

/* 滚动到底部的额外留白 */
.safe-area-spacer {
  height: 40rpx;
}

