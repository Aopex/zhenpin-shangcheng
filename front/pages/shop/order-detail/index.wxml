<view class="container detail-page">
  <scroll-view class="detail-scroll" scroll-y wx:if="{{order}}">
    <view class="status-panel {{order.status === 'UNPAID' ? 'is-primary' : ''}}">
      <view class="status-copy">
        <text class="status-text">{{order.statusText}}</text>
        <text class="status-sub">订单号 {{order.orderNo}}</text>
      </view>
      <view class="status-chip">{{order.statusShortText}}</view>
    </view>

    <view class="address-card">
      <view class="address-mark"></view>
      <view class="address-content" wx:if="{{order.address}}">
        <view class="address-top">
          <text class="address-name">{{order.address.name}}</text>
          <text class="address-phone">{{order.address.phone}}</text>
        </view>
        <text class="address-line">{{order.address.address}}</text>
      </view>
      <view class="address-content" wx:else>
        <text class="address-name">暂无收货地址</text>
        <text class="address-line">该订单没有保存地址快照</text>
      </view>
    </view>

    <view class="section-label">商品明细</view>
    <view class="goods-card">
      <block wx:for="{{order.goods}}" wx:key="id">
        <view class="goods-item">
          <image class="goods-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-title">{{item.title}}</text>
            <text class="goods-spec" wx:if="{{item.specText}}">{{item.specText}}</text>
          </view>
          <view class="goods-price">
            <text class="goods-unit">¥{{item.price}}</text>
            <text class="goods-count">x{{item.count}}</text>
            <text class="goods-subtotal">¥{{item.subtotal}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="section-label">金额构成</view>
    <view class="summary-card">
      <view class="summary-row">
        <text class="summary-label">商品金额</text>
        <text class="summary-value">¥{{order.goodsAmount}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">运费</text>
        <text class="summary-value">¥{{order.freightAmount}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">优惠金额</text>
        <text class="summary-value discount">- ¥{{order.discountAmount}}</text>
      </view>
      <view class="summary-row total-row">
        <text class="summary-label">实付金额</text>
        <text class="summary-total">¥{{order.totalAmount}}</text>
      </view>
    </view>

    <view class="section-label">订单信息</view>
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">订单编号</text>
        <text class="info-value">{{order.orderNo}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">买家备注</text>
        <text class="info-value">{{order.remark || '无备注'}}</text>
      </view>
      <block wx:for="{{timeRows}}" wx:key="label">
        <view class="info-row">
          <text class="info-label">{{item.label}}</text>
          <text class="info-value">{{item.value}}</text>
        </view>
      </block>
    </view>

    <view class="bottom-scroll-spacer"></view>
  </scroll-view>

  <view class="action-bar" wx:if="{{order && hasBottomActions}}">
    <view class="action-content safe-area-bottom">
      <block wx:if="{{order.status === 'UNPAID'}}">
        <view class="action-btn secondary" bindtap="cancelOrder" hover-class="btn-active-feedback">取消订单</view>
        <view class="action-btn primary" bindtap="payOrder" hover-class="btn-active-feedback">去支付</view>
      </block>
      <block wx:elif="{{order.status === 'UNSHIPPED'}}">
        <view class="action-btn primary single" bindtap="remindShip" hover-class="btn-active-feedback">提醒发货</view>
      </block>
      <block wx:elif="{{order.status === 'UNRECEIVED'}}">
        <view class="action-btn primary single" bindtap="confirmReceive" hover-class="btn-active-feedback">确认收货</view>
      </block>
      <block wx:elif="{{order.status === 'FINISHED'}}">
        <view class="action-btn primary single" bindtap="deleteOrder" hover-class="btn-active-feedback">删除订单</view>
      </block>
    </view>
  </view>
</view>
