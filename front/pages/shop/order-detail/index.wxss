.detail-page {
  height: 100vh;
  overflow: hidden;
  background: var(--bg-page);
}

.detail-scroll {
  height: 100vh;
  background: var(--bg-page);
}

.status-panel {
  margin: 32rpx 32rpx 28rpx;
  padding: 34rpx 32rpx;
  border-radius: 32rpx;
  background: var(--text-main);
  color: #FFFFFF;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-shadow: 0 18rpx 42rpx -24rpx rgba(54,46,45,0.65);
}

.status-panel.is-primary {
  background: var(--primary);
}

.status-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.status-text {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

.status-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.72);
  font-family: 'Bahnschrift', monospace;
}

.status-chip {
  padding: 8rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.14);
  color: rgba(255,255,255,0.82);
  font-size: 22rpx;
  font-family: 'Bahnschrift', monospace;
}

.section-label {
  margin: 28rpx 32rpx 16rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 600;
}

.address-card,
.goods-card,
.summary-card,
.info-card {
  margin: 0 32rpx;
  border-radius: 32rpx;
  background: var(--bg-card);
  box-shadow: 0 10rpx 40rpx -18rpx rgba(54,46,45,0.12);
}

.address-card {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx 32rpx 28rpx;
}

.address-mark {
  width: 8rpx;
  height: 92rpx;
  border-radius: 8rpx;
  background: var(--primary);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.address-content {
  flex: 1;
  min-width: 0;
}

.address-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.address-name {
  font-size: 32rpx;
  color: var(--text-main);
  font-weight: 700;
  margin-right: 16rpx;
}

.address-phone {
  font-size: 28rpx;
  color: var(--text-main);
  font-family: 'Bahnschrift', monospace;
}

.address-line {
  display: block;
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 38rpx;
}

.goods-card {
  overflow: hidden;
}

.goods-item {
  display: flex;
  padding: 28rpx;
  border-bottom: 1rpx solid rgba(235,229,223,0.72);
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 24rpx;
  background: var(--bg-input);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.goods-title {
  color: var(--text-main);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-spec {
  display: block;
  margin-top: 10rpx;
  color: var(--text-muted);
  font-size: 23rpx;
}

.goods-price {
  width: 136rpx;
  margin-left: 18rpx;
  text-align: right;
  font-family: 'Bahnschrift', monospace;
}

.goods-unit {
  display: block;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 700;
}

.goods-count {
  display: block;
  margin-top: 12rpx;
  color: var(--text-muted);
  font-size: 24rpx;
}

.goods-subtotal {
  display: block;
  margin-top: 16rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.summary-card,
.info-card {
  padding: 16rpx 28rpx;
}

.summary-row,
.info-row {
  min-height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(235,229,223,0.72);
}

.summary-row:last-child,
.info-row:last-child {
  border-bottom: none;
}

.summary-label,
.info-label {
  color: var(--text-muted);
  font-size: 26rpx;
  flex-shrink: 0;
}

.summary-value,
.info-value {
  margin-left: 24rpx;
  color: var(--text-main);
  font-size: 26rpx;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.discount {
  color: var(--primary);
}

.total-row {
  min-height: 88rpx;
}

.summary-total {
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 800;
  font-family: 'Bahnschrift', monospace;
}

.bottom-scroll-spacer {
  height: calc(188rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.04);
}

.action-content {
  min-height: 112rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.action-btn {
  height: 78rpx;
  min-width: 176rpx;
  padding: 0 34rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.action-btn.single {
  min-width: 236rpx;
}

.action-btn.secondary {
  color: var(--text-main);
  border: 2rpx solid rgba(235,229,223,0.9);
  background: #FFFFFF;
}

.action-btn.primary {
  color: #FFFFFF;
  background: var(--text-main);
  box-shadow: 0 12rpx 24rpx -14rpx rgba(54,46,45,0.5);
}

.btn-active-feedback {
  transform: scale(0.96);
  opacity: 0.9;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
