<!--pages/tabs/order/index.wxml-->
<view class="container order-container">
  
  <!-- 顶部状态导航栏 -->
  <view class="tabs">
    <block wx:for="{{tabs}}" wx:key="id">
      <view class="tab-item {{currentStatus === item.status ? 'active' : ''}}" 
            bindtap="switchTab" 
            data-status="{{item.status}}">
        <text class="tab-text">{{item.name}}</text>
      </view>
    </block>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-list" scroll-y>
    <block wx:for="{{displayOrders}}" wx:key="id">
      <view class="card order-card">
        <!-- 订单头部 -->
        <view class="order-header">
          <text class="order-no">订单号：{{item.orderNo}}</text>
          <text class="order-status {{item.status === 'UNPAID' ? 'status-primary' : (item.status === 'UNSHIPPED' || item.status === 'UNRECEIVED' ? 'status-accent' : '')}}">{{item.statusText}}</text>
        </view>
        
        <!-- 订单商品区域 -->
        <view class="order-goods" bindtap="toDetail" data-id="{{item.id}}">
          <!-- 单件商品详情展示 -->
          <block wx:if="{{item.goods.length === 1}}">
            <view class="single-good">
              <image class="good-img" src="{{item.goods[0].imageUrl}}" mode="aspectFill"></image>
              <view class="good-info">
                <text class="good-title">{{item.goods[0].title}}</text>
                <view class="good-bottom">
                  <text class="good-price">¥{{item.goods[0].price}}</text>
                  <text class="good-count">x{{item.goods[0].count}}</text>
                </view>
              </view>
            </view>
          </block>
          <!-- 多件商品横向滑动展示 -->
          <block wx:else>
            <scroll-view class="multi-goods" scroll-x>
              <view class="goods-scroll-wrap">
                <block wx:for="{{item.goods}}" wx:key="id" wx:for-item="good">
                  <image class="good-img-small" src="{{good.imageUrl}}" mode="aspectFill"></image>
                </block>
              </view>
            </scroll-view>
          </block>
        </view>
        
        <!-- 订单底部 (金额 + 操作按钮) -->
        <view class="order-footer">
          <view class="order-total">
            <text class="total-text">共{{item.totalCount}}件商品 实付金额：</text>
            <text class="total-price">¥{{item.totalAmount}}</text>
          </view>
          <view class="order-actions">
            <!-- 根据状态显示不同按钮 -->
            <block wx:if="{{item.status === 'UNPAID'}}">
              <view class="btn btn-default" catchtap="cancelOrder" data-id="{{item.id}}">取消订单</view>
              <view class="btn btn-primary" catchtap="payOrder" data-id="{{item.id}}">去支付</view>
            </block>
            <block wx:elif="{{item.status === 'UNSHIPPED'}}">
              <view class="btn btn-default" catchtap="remindShip" data-id="{{item.id}}">提醒发货</view>
            </block>
            <block wx:elif="{{item.status === 'UNRECEIVED'}}">
              <view class="btn btn-primary" catchtap="confirmReceive" data-id="{{item.id}}">确认收货</view>
            </block>
            <block wx:elif="{{item.status === 'FINISHED'}}">
              <view class="btn btn-default" catchtap="deleteOrder" data-id="{{item.id}}">删除订单</view>
            </block>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-tip" wx:if="{{displayOrders.length === 0}}">
      <text>暂无相关订单</text>
    </view>

    <!-- 底部占位：滑到底部才露出的间距 -->
    <view class="list-tail-spacer"></view>
  </scroll-view>
</view>
