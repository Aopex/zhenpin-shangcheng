/* pages/tabs/cart/index.wxss */
.cart-container {
  /* 预留底部结算栏高度 */
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-page);
  min-height: 100vh;
}

/* 交互动画 */
.btn-active-feedback {
  transform: scale(0.96) !important;
  opacity: 0.9 !important;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1) !important;
}
.icon-active-feedback {
  transform: scale(0.85);
  opacity: 0.7;
  transition: all 0.2s ease;
}

/* 空状态 (Art Gallery Mode) */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}
.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 48rpx;
}
.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-bottom: 60rpx;
  letter-spacing: -0.5rpx;
}
.go-shopping-btn {
  width: 280rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: var(--text-main);
  color: #FFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.15);
  transition: all 0.2s;
}

/* 购物车列表 (Bento Grid Style) */
.cart-list {
  padding: 32rpx 0;
}
.cart-swipe-shell {
  position: relative;
  margin: 0 32rpx 32rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(203, 64, 66, 0.08);
  box-shadow: 0 10rpx 40rpx -15rpx rgba(0,0,0,0.04);
}
.delete-action {
  position: absolute;
  top: 0;
  right: 0;
  width: 132rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.delete-circle {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.18), 0 12rpx 26rpx -14rpx rgba(203,64,66,0.8);
  position: relative;
}
.trash-lid {
  position: absolute;
  top: 24rpx;
  width: 30rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: #FFFFFF;
}
.trash-lid::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: -5rpx;
  width: 10rpx;
  height: 5rpx;
  border-radius: 5rpx 5rpx 0 0;
  background: #FFFFFF;
}
.trash-can {
  width: 26rpx;
  height: 28rpx;
  margin-top: 12rpx;
  border: 4rpx solid #FFFFFF;
  border-top: none;
  border-radius: 0 0 7rpx 7rpx;
  display: flex;
  justify-content: space-evenly;
  align-items: center;
  padding: 5rpx 3rpx 3rpx;
}
.trash-line {
  width: 3rpx;
  height: 16rpx;
  border-radius: 3rpx;
  background: rgba(255,255,255,0.9);
}
.delete-active-feedback {
  transform: scale(0.94);
  opacity: 0.86;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.cart-item {
  margin: 0;
  border-radius: 32rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  padding: 32rpx;
  box-shadow: none;
}
.cart-swipe-content {
  position: relative;
  transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  will-change: transform;
}
.cart-swipe-content.is-swiping {
  transition: none;
}

/* 自定义选框 */
.checkbox-box {
  width: 60rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}
.checkbox-uncheck {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  border: 3rpx solid rgba(235, 229, 223, 0.8);
  background-color: transparent;
  box-sizing: border-box;
}
.checkbox-checked {
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background-color: var(--text-main);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx -4rpx rgba(0,0,0,0.2);
}
.check-mark {
  width: 12rpx;
  height: 20rpx;
  border: solid #FFF;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
  margin-top: -4rpx;
}

.item-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx; /* Softer radius */
  background-color: var(--bg-input);
  flex-shrink: 0;
  margin-right: 32rpx;
}
.item-info {
  flex: 1;
  height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 44rpx;
  letter-spacing: -0.5rpx;
}
.item-spec {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}
.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: bottom;
  align-items: flex-end;
}
.item-price {
  color: var(--primary); /* Theme red accent */
  font-family: 'Bahnschrift', monospace;
}
.price-symbol {
  font-size: 26rpx;
  margin-right: 4rpx;
  font-weight: 600;
  color: var(--primary);
}
.price-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

/* 数量加减器 (Clean Capsule) */
.stepper {
  display: flex;
  align-items: center;
  background-color: var(--bg-page);
  border-radius: 32rpx;
  padding: 4rpx;
}
.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  border-radius: 28rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-main);
}
.stepper-btn.disabled {
  color: var(--border-light);
  background-color: transparent;
}
.stepper-num {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Bahnschrift', monospace;
  color: var(--text-main);
}

/* 底部结算栏 (Floating Glassmorphism) */
.settlement-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  z-index: 99;
}
.settlement-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  height: 112rpx; /* base height before safe-area */
}

.check-all {
  display: flex;
  align-items: center;
  height: 100%;
}
.check-all-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-muted);
  margin-left: 16rpx;
}
.settlement-info {
  display: flex;
  align-items: center;
}
.total-box {
  display: flex;
  align-items: baseline;
  margin-right: 32rpx;
}
.total-label {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-right: 12rpx;
}
.total-price {
  font-size: 40rpx;
  color: var(--primary);
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
}

/* 结算按钮 */
.checkout-btn {
  padding: 0 48rpx;
  height: 88rpx;
  background-color: var(--text-main);
  color: #FFFFFF;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.15);
}
.checkout-btn.disabled {
  background-color: var(--bg-input);
  color: var(--text-muted);
  box-shadow: none;
}
