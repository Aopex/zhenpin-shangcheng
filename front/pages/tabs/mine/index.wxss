/* pages/tabs/mine/index.wxss */
.mine-container {
  background-color: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 交互反馈 (Tactile Feedback) */
.active-feedback {
  opacity: 0.8;
  transform: scale(0.98);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 头部视觉 / Asymmetric */
.user-info {
  background: var(--bg-card);
  padding: 72rpx 40rpx 64rpx;
  display: flex;
  align-items: center;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 20rpx 40rpx -15rpx rgba(0, 0, 0, 0.05); /* Diffusion shadow */
  position: relative;
  z-index: 10;
}
.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx; /* Squircle */
  margin-right: 32rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2); /* Liquid glass subtle touch */
  background-color: var(--bg-input);
}
.user-detail {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 16rpx;
  letter-spacing: -1rpx; /* tracking-tighter */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.user-desc {
  font-size: 26rpx;
  color: var(--text-muted);
}
.user-meta {
  display: flex;
  align-items: center;
  min-height: 44rpx;
}
.user-phone {
  max-width: 360rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  font-family: 'Bahnschrift', monospace;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分组区块 */
.section-group {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.order-panel, .menu-list {
  background-color: var(--bg-card);
  border-radius: 32rpx;
  padding: 8rpx; /* inner shell for spacing */
  box-shadow: 0 10rpx 30rpx -10rpx rgba(0,0,0,0.02);
}

/* 面板头部 */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
}
.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: -0.5rpx;
}
.panel-more {
  display: flex;
  align-items: center;
}
.more-text {
  font-size: 24rpx;
  color: var(--text-muted);
}
.arrow-icon {
  font-size: 36rpx;
  color: var(--text-muted);
  margin-left: 8rpx;
  font-family: monospace; /* Simple sleek arrow */
  line-height: 1;
}

/* 订单九宫格 */
.order-icons {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 24rpx 32rpx;
}
.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
  transition: all 0.2s ease;
}
.icon-img {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 20rpx;
}
.icon-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-main);
}

/* 菜单列表区 */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 24rpx;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4); /* transparent var(--border-light) */
  transition: all 0.2s ease;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-text {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
}
.logout-item {
  justify-content: space-between;
}
.logout-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}
.logout-arrow {
  color: var(--primary);
}

/* 覆盖button默认样式 */
.plain-btn {
  margin: 0 !important;
  padding: 36rpx 24rpx !important;
  background-color: transparent;
  line-height: normal;
  border-radius: 0;
  box-sizing: border-box;
  text-align: left;
  width: 100% !important;
  font-weight: normal;
}
.plain-btn::after {
  display: none;
}
