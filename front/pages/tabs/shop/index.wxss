/* pages/tabs/shop/index.wxss */
.shop-container {
  flex-direction: row; /* 水平布局 */
  height: 100vh;
  background-color: var(--bg-page);
}

/* 左侧分类栏 */
.category-sidebar {
  width: 220rpx; /* Slightly wider for breathing room */
  height: 100%;
  background-color: var(--bg-page); /* Merge with page bg instead of grey */
  flex-shrink: 0;
  border-right: 1rpx solid rgba(0,0,0,0.03);
}

.category-item {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  font-size: 26rpx;
  color: var(--text-muted);
  background-color: transparent;
  transition: color 0.25s cubic-bezier(0.16, 1, 0.3, 1),
              font-weight 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Active state: left accent bar + subtle bg + bold text */
.category-item.active {
  background-color: var(--bg-card);
  font-weight: 600;
  color: var(--text-main);
  border-radius: 24rpx 0 0 24rpx;
}

/* Accent bar indicator — real DOM for smooth transition */
.indicator-bar {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%) scaleY(0);
  width: 6rpx;
  height: 36rpx;
  background-color: var(--text-main);
  border-radius: 0 3rpx 3rpx 0;
  opacity: 0;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
              opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.category-item.active .indicator-bar {
  transform: translateY(-50%) scaleY(1);
  opacity: 1;
}

/* Hover feedback on inactive items */
.category-item:not(.active):active {
  color: var(--text-main);
  opacity: 0.6;
}

/* 右侧商品区 */
.product-list-view {
  flex: 1;
  height: 100%;
  background-color: var(--bg-card);
  box-sizing: border-box;
}

.category-header {
  padding: 32rpx 40rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: sticky;
  top: 0;
  z-index: 10;
}

.category-title {
  font-size: 40rpx; /* Bigger layout typography contrast */
  color: var(--text-main);
  font-weight: 700;
  letter-spacing: -1rpx;
}

.product-list {
  padding: 0 32rpx 40rpx;
}

.product-item {
  display: flex;
  padding: 32rpx 0;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Interactive States */
.product-active-feedback {
  opacity: 0.8;
  transform: scale(0.98);
}
.icon-active-feedback {
  transform: scale(0.85);
  opacity: 0.7;
}

.product-item:last-child {
  border-bottom: none;
}

.product-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background-color: var(--bg-input);
  margin-right: 32rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.product-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-main);
  /* 两行省略 */
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 44rpx;
  letter-spacing: -0.5rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: bottom;
  align-items: flex-end;
}

.product-price {
  color: var(--primary); /* Theme red accent */
}

.price-symbol {
  font-size: 26rpx;
  margin-right: 4rpx;
  font-weight: 600;
  color: var(--primary);
}

.price-num {
  font-size: 36rpx;
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
  color: var(--primary);
}

.add-cart-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  background-color: var(--text-main);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx -4rpx rgba(0,0,0,0.2);
  transition: all 0.2s;
}

.plus-icon {
  color: #FFF;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 1;
  margin-top: -4rpx; /* visual center hack */
}

.empty-tip {
  text-align: center;
  padding: 160rpx 0;
  color: var(--text-muted);
  font-size: 28rpx;
  font-weight: 500;
}

/* SKU 弹窗 */
.sku-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 999;
  animation: fadeIn 0.3s ease forwards;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.sku-popup {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background-color: var(--bg-card);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  z-index: 1000;
  transform: translateY(calc(100% + env(safe-area-inset-bottom)));
  visibility: hidden;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.4s;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1);
  padding-bottom: env(safe-area-inset-bottom);
}
.sku-popup.show {
  transform: translateY(0);
  visibility: visible;
}
.sku-header {
  display: flex;
  padding: 40rpx 32rpx;
  position: relative;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}
.sku-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background-color: var(--bg-input);
  margin-top: -60rpx;
  border: 4rpx solid var(--bg-card);
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.1);
}
.sku-header-info {
  margin-left: 32rpx;
  flex: 1;
}
.sku-price {
  color: var(--primary);
  font-size: 40rpx;
  font-weight: 700;
  font-family: 'Bahnschrift', monospace;
}
.sku-stock, .sku-selected {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}
.sku-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 48rpx;
  color: var(--text-muted);
  line-height: 1;
  padding: 10rpx;
  transition: transform 0.2s ease;
}
.sku-close:active {
  transform: scale(0.8) rotate(90deg);
}
.sku-body {
  max-height: 50vh;
  padding: 0;
}
.sku-group {
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(235, 229, 223, 0.4);
}
.sku-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
}
.sku-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.sku-tag {
  padding: 12rpx 32rpx;
  background-color: var(--bg-page);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-main);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}
.sku-tag:active {
  transform: scale(0.95);
}
.sku-tag.active {
  background-color: var(--text-main);
  color: #FFF;
  border-color: var(--text-main);
}
.sku-tag.disabled {
  color: var(--border-light);
  background-color: var(--bg-page);
  opacity: 0.5;
  pointer-events: none;
}
.sku-count-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.stepper {
  display: flex;
  align-items: center;
  background-color: var(--bg-page);
  border-radius: 32rpx;
  padding: 4rpx;
}
.stepper-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-main);
  transition: all 0.2s;
}
.stepper-btn:active {
  background-color: rgba(0,0,0,0.05);
  border-radius: 28rpx;
}
.stepper-num {
  width: 70rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'Bahnschrift', monospace;
}
.sku-footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid rgba(235, 229, 223, 0.4);
}
.btn-action {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 42rpx;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.btn-action:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.btn-sku-confirm {
  background-color: var(--text-main);
  color: #FFF;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.2);
}

/* 抛物线飞入购物车 */
.fly-img {
  position: fixed;
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  z-index: 9999;
  pointer-events: none;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(0,0,0,0.2);
}
.fly-img.fly-parabola {
  animation: fly-parabola 0.45s ease-in forwards;
}
@keyframes fly-parabola {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(var(--dx), var(--dy)) scale(0.3); opacity: 0.4; }
}
