.about-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 40rpx;
}

.active-feedback {
  opacity: 0.8;
  transform: scale(0.98);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.about-hero {
  margin: 32rpx;
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  box-shadow: 0 10rpx 30rpx -12rpx rgba(0,0,0,0.04);
}

.brand-mark {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: var(--text-main);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.brand-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.brand-title {
  color: var(--text-main);
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.brand-subtitle {
  color: var(--text-muted);
  font-size: 25rpx;
  line-height: 36rpx;
  margin-top: 12rpx;
}

.section-block {
  padding: 0 32rpx;
  margin-top: 28rpx;
}

.info-panel {
  background: var(--bg-card);
  border-radius: 32rpx;
  padding: 8rpx;
  box-shadow: 0 10rpx 30rpx -10rpx rgba(0,0,0,0.02);
}

.panel-head {
  padding: 28rpx 24rpx 18rpx;
}

.panel-title {
  color: var(--text-main);
  font-size: 31rpx;
  font-weight: 700;
}

.intro-text {
  display: block;
  padding: 0 24rpx 30rpx;
  color: var(--text-muted);
  font-size: 27rpx;
  line-height: 44rpx;
}

.list-row {
  display: flex;
  align-items: flex-start;
  padding: 28rpx 24rpx;
  border-top: 1rpx solid rgba(235, 229, 223, 0.4);
}

.row-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: var(--text-main);
  margin-top: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.row-text {
  flex: 1;
  color: var(--text-main);
  font-size: 27rpx;
  line-height: 42rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  border-top: 1rpx solid rgba(235, 229, 223, 0.4);
}

.meta-label {
  color: var(--text-muted);
  font-size: 27rpx;
}

.meta-value {
  max-width: 420rpx;
  color: var(--text-main);
  font-size: 27rpx;
  font-weight: 600;
  text-align: right;
}

.contact-btn {
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--text-main);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 88rpx;
  box-shadow: 0 10rpx 20rpx -10rpx rgba(0,0,0,0.2);
}

.contact-btn::after {
  display: none;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
