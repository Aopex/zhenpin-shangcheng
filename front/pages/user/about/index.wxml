<view class="container about-page {{showAnimation ? 'is-ready' : ''}}">
  <view class="hero-section stagger-1">
    <view class="hero-left">
      <view class="hero-title-group">
        <text class="hero-title">臻品商城</text>
        <text class="hero-primary">Zhenpin Mall.</text>
      </view>
    </view>
  </view>
  <view class="bento-grid">
    <view class="bento-card bento-intro staggered-item stagger-2">
      <view class="card-header">
        <view class="header-dot"></view>
        <text class="card-title">项目简介</text>
      </view>
      <text class="intro-desc">臻品商城是一款专注于精选好物的微信小程序商城。本课设项目聚焦电商核心业务逻辑，力求打造极致的用户查单与购物体验，优先保证课设场景中的功能闭环。</text>
    </view>
    <view class="bento-card staggered-item stagger-3">
      <view class="card-header">
        <view class="header-dot"></view>
        <text class="card-title">开发成员</text>
      </view>
      <view class="team-list">
        <block wx:for="{{team}}" wx:key="name">
          <view class="team-member" style="transition-delay: {{index * 100 + 300}}ms">
            <view class="member-role">{{item.role}}</view>
            <view class="member-name">{{item.name}}</view>
          </view>
        </block>
      </view>
    </view>
    <view class="bento-card staggered-item stagger-4">
      <view class="card-header">
        <view class="header-dot"></view>
        <text class="card-title">技术选型</text>
      </view>
      <view class="tech-stack-list">
        <block wx:for="{{techStack}}" wx:key="title">
          <view class="tech-item">
            <view class="tech-title">{{item.title}}</view>
            <view class="tech-desc">{{item.desc}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>
  <view class="safe-area-bottom"></view>
</view>
